---
interface Props {
  activePage?: string;
}
const { activePage = '' } = Astro.props;
---

<nav class="navbar" id="home">
  <div class="container">
    <a href="/" class="navbar__logo"><img src="/srs_logo.png" alt="Square Root SEO" style="width:120px; height:auto;"></a>
    <div class="navbar__links">
      <a href="/" class:list={[{ active: activePage === 'home' }]}>Home</a>
      <a href="/about" class:list={[{ active: activePage === 'about' }]}>About</a>
      <div class="navbar__dropdown">
        <a href="#" class="navbar__dropdown-trigger">Services <i class="fa-solid fa-chevron-down"></i></a>
        <div class="navbar__dropdown-menu navbar__mega-menu">
          <div class="mega-col">
            <div class="mega-col__header"><i class="fa-solid fa-hammer"></i> Foundry</div>
            <a href="/seo">Search Engine Optimization</a>
            <a href="/website-development">Website Development</a>
          </div>
          <div class="mega-col">
            <div class="mega-col__header"><i class="fa-solid fa-industry"></i> Digital Factory</div>
            <a href="/seo">Search Engine Optimization</a>
            <a href="/website-development">Website Development</a>
            <a href="/social-media">Social Media Management</a>
          </div>
          <div class="mega-col">
            <div class="mega-col__header"><i class="fa-solid fa-rocket"></i> Domination</div>
            <a href="/seo">Search Engine Optimization</a>
            <a href="/website-development">Website Development</a>
            <a href="/social-media">Social Media Management</a>
            <a href="/ppc">Pay Per Click (PPC)</a>
            <a href="/branding">Branding</a>
          </div>
        </div>
      </div>
      <!-- Mobile-only flat service links -->
      <span class="mobile-service-heading">Services</span>
      <a href="/seo" class="mobile-service-link">Search Engine Optimization</a>
      <a href="/website-development" class="mobile-service-link">Website Development</a>
      <a href="/ppc" class="mobile-service-link">Pay Per Click (PPC)</a>
      <a href="/social-media" class="mobile-service-link">Social Media Management</a>
      <a href="/branding" class="mobile-service-link">Branding</a>
      <a href="/acid-test">A.C.I.D Framework</a>
      <a href="/case-studies">Case Studies</a>
      <a href="/blog">Blog</a>
      <a href="/contact">Contact</a>
      <a href="/contact" class="common-btn p1-bg box-style">Build My Factory <i class="fa-solid fa-arrow-right-long"></i></a>
    </div>
    <button class="navbar__hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
  </div>
</nav>
