---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="A.C.I.D Test — Free SEO Audit for B2B Manufacturers | Square Root SEO" description="Take the A.C.I.D Test — a free 25-point SEO audit for B2B manufacturers. Discover where your Digital Factory is leaking leads and how to fix it." activePage="acid-test">

<!-- HERO -->
<section class="acid-page-hero">
  <div class="acid-page-hero__inner container">
    <div class="acid-page-hero__content">
      <span class="cmn-tag p2-bg">Proprietary Framework</span>
      <h1 class="acid-page-hero__lead">The <span class="p1-clr">A.C.I.D</span> Framework</h1>
      <p class="acid-page-hero__sub">A structured, 4-phase system built exclusively for B2B industrial companies. Every phase is designed around how procurement officers actually search, evaluate, and buy online.</p>
      <div class="acid-page-hero__stats">
        <div class="acid-page-hero__stat"><div class="acid-page-hero__stat-num p1-clr">50+</div><div>Factories Built</div></div>
        <div class="acid-page-hero__stat"><div class="acid-page-hero__stat-num p3-clr">350%</div><div>Traffic Growth</div></div>
        <div class="acid-page-hero__stat"><div class="acid-page-hero__stat-num p2-clr">4</div><div>Framework Phases</div></div>
      </div>
    </div>
    <div class="acid-page-hero__visual">
      <div class="acid-page-hero__badge">
        <div class="acid-page-hero__badge-letters">
          <span>A</span><span class="acid-page-hero__badge-dot">.</span><span>C</span><span class="acid-page-hero__badge-dot">.</span><span>I</span><span class="acid-page-hero__badge-dot">.</span><span>D</span>
        </div>
        <div class="acid-page-hero__badge-sub">FRAMEWORK</div>
        <div class="acid-page-hero__badge-by">by Square Root SEO</div>
      </div>
    </div>
  </div>
</section>

<section class="acid-usp">
  <div class="container">
    <div class="section-title text-center reveal">
      <span class="cmn-tag p3-bg" style="color:var(--n900-clr);">Why A.C.I.D?</span>
      <h2>Built for Manufacturers. Not Generic Businesses.</h2>
      <p style="color:var(--text-muted); max-width:700px; margin:0 auto;">Unlike typical SEO packages, the A.C.I.D Framework is purpose-built for B2B industrial companies. Every phase is designed around how procurement officers, dealers, and purchase managers actually search, evaluate, and buy online.</p>
    </div>
    <div class="acid-usp__grid reveal">
      <div class="acid-usp__item">
        <i class="fa-solid fa-industry"></i>
        <h4>Industry-Specific</h4>
        <p>We work exclusively with B2B manufacturers — packaging, chemicals, automation, textiles, and industrial supplies.</p>
      </div>
      <div class="acid-usp__item">
        <i class="fa-solid fa-magnifying-glass-chart"></i>
        <h4>Data-First Approach</h4>
        <p>Every decision is backed by keyword data, competitor analysis, and buyer intent mapping — not guesswork.</p>
      </div>
      <div class="acid-usp__item">
        <i class="fa-solid fa-robot"></i>
        <h4>Automated Lead Flow</h4>
        <p>CRM, WhatsApp, and lead form integrations ensure every enquiry is captured, logged, and followed up.</p>
      </div>
      <div class="acid-usp__item">
        <i class="fa-solid fa-shield-halved"></i>
        <h4>E-E-A-T Compliant</h4>
        <p>We build content that satisfies Google's Experience, Expertise, Authority, and Trust signals for industrial niches.</p>
      </div>
    </div>
  </div>
</section>

<!-- A.C.I.D STEPS — ZIGZAG LAYOUT -->
<section class="acid-steps" id="acid-steps">
  <div class="container">
    <div class="section-title text-center reveal">
      <span class="cmn-tag p1-bg">The 4 Phases</span>
      <h2>How the A.C.I.D Framework Works</h2>
    </div>

    <!-- STEP 1: ARCHITECT -->
    <div class="acid-step reveal">
      <div class="acid-step__card" style="--step-clr: #206dff; --step-clr-soft: rgba(32,109,255,0.08);">
        <div class="acid-step__letter">A</div>
        <div class="acid-step__badge">Phase 01</div>
        <div class="acid-step__icon"><i class="fa-solid fa-compass-drafting"></i></div>
        <h3>Architect</h3>
        <p>We reverse-engineer how your ideal B2B buyer searches on Google, then design your entire digital blueprint accordingly.</p>
        <ul class="acid-step__list">
          <li><i class="fa-solid fa-check"></i> Full technical SEO audit of your current site</li>
          <li><i class="fa-solid fa-check"></i> Industrial keyword + competitor mapping</li>
          <li><i class="fa-solid fa-check"></i> Site architecture and URL hierarchy planning</li>
          <li><i class="fa-solid fa-check"></i> Page-by-page content roadmap</li>
        </ul>
      </div>
      <div class="acid-step__info">
        <h4>Why Architecture Matters</h4>
        <p>Most B2B websites are built like brochures — flat, unfocused, and invisible to Google. The Architect phase lays the structural foundation so every page you build has a clear purpose, targets real buyer keywords, and feeds into your overall lead generation funnel.</p>
        <div class="acid-step__outcome">
          <i class="fa-solid fa-bullseye"></i>
          <span><strong>Outcome:</strong> A complete digital blueprint that maps your products and services to your buyer's search journey.</span>
        </div>
      </div>
    </div>

    <!-- STEP 2: CONTENT -->
    <div class="acid-step acid-step--reverse reveal">
      <div class="acid-step__card" style="--step-clr: #ffb525; --step-clr-soft: rgba(255,181,37,0.08);">
        <div class="acid-step__letter">C</div>
        <div class="acid-step__badge">Phase 02</div>
        <div class="acid-step__icon" style="color:#ffb525;"><i class="fa-solid fa-pen-nib"></i></div>
        <h3>Content</h3>
        <p>We create E-E-A-T focused content written for procurement officers and purchase managers — not generic blog filler.</p>
        <ul class="acid-step__list" style="--check-clr: #ffb525;">
          <li><i class="fa-solid fa-check"></i> E-E-A-T content strategy and editorial calendar</li>
          <li><i class="fa-solid fa-check"></i> 50+ industrial product and category pages</li>
          <li><i class="fa-solid fa-check"></i> Buyer-first copywriting that converts</li>
          <li><i class="fa-solid fa-check"></i> Case studies, blogs, and authority content</li>
        </ul>
      </div>
      <div class="acid-step__info">
        <h4>Content That Builds Authority</h4>
        <p>Google now prioritises real-world experience and expertise. Our content is written by people who understand manufacturing — product specifications, compliance certifications, and industrial use cases that procurement officers actually care about.</p>
        <div class="acid-step__outcome">
          <i class="fa-solid fa-bullseye"></i>
          <span><strong>Outcome:</strong> A content library that positions your brand as the undeniable industry authority on Google.</span>
        </div>
      </div>
    </div>

    <!-- STEP 3: INTEGRATION -->
    <div class="acid-step reveal">
      <div class="acid-step__card" style="--step-clr: #ec191e; --step-clr-soft: rgba(236,25,30,0.08);">
        <div class="acid-step__letter">I</div>
        <div class="acid-step__badge">Phase 03</div>
        <div class="acid-step__icon" style="color:#ec191e;"><i class="fa-solid fa-plug-circle-bolt"></i></div>
        <h3>Integration</h3>
        <p>We connect every piece of your digital factory so leads flow automatically from Google to your sales team.</p>
        <ul class="acid-step__list" style="--check-clr: #ec191e;">
          <li><i class="fa-solid fa-check"></i> CRM and lead capture form setup</li>
          <li><i class="fa-solid fa-check"></i> WhatsApp Business API automation</li>
          <li><i class="fa-solid fa-check"></i> Google Search Console + Analytics wiring</li>
          <li><i class="fa-solid fa-check"></i> Call tracking and enquiry attribution</li>
        </ul>
      </div>
      <div class="acid-step__info">
        <h4>No Lead Left Behind</h4>
        <p>Traffic without capture is wasted. The Integration phase ensures every website visitor who shows buying intent is captured, logged, and routed to your sales team — via form, WhatsApp, or phone — with zero manual effort.</p>
        <div class="acid-step__outcome">
          <i class="fa-solid fa-bullseye"></i>
          <span><strong>Outcome:</strong> A fully automated lead capture pipeline that feeds your CRM without lifting a finger.</span>
        </div>
      </div>
    </div>

    <!-- STEP 4: DATA & DOMINATION -->
    <div class="acid-step acid-step--reverse reveal">
      <div class="acid-step__card" style="--step-clr: #206dff; --step-clr-soft: rgba(32,109,255,0.08);">
        <div class="acid-step__letter">D</div>
        <div class="acid-step__badge">Phase 04</div>
        <div class="acid-step__icon"><i class="fa-solid fa-chart-column"></i></div>
        <h3>Data &amp; Domination</h3>
        <p>We track, measure, and optimise relentlessly until your factory dominates your entire product category on Google.</p>
        <ul class="acid-step__list">
          <li><i class="fa-solid fa-check"></i> Monthly rank and traffic reporting</li>
          <li><i class="fa-solid fa-check"></i> Bi-weekly strategy and optimisation calls</li>
          <li><i class="fa-solid fa-check"></i> Lead attribution and ROI tracking</li>
          <li><i class="fa-solid fa-check"></i> Category domination roadmap</li>
        </ul>
      </div>
      <div class="acid-step__info">
        <h4>Relentless Optimisation</h4>
        <p>SEO is not a one-time project. The Data phase is your unfair advantage — monthly reporting, bi-weekly strategy calls, and continuous optimisation that compounds your results month after month until competitors simply cannot catch up.</p>
        <div class="acid-step__outcome">
          <i class="fa-solid fa-bullseye"></i>
          <span><strong>Outcome:</strong> Complete Google domination for your product category with compounding, data-driven results.</span>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ACID TEST CTA -->
<section class="acid-cta" id="acid-test">
  <div class="container">
    <div class="acid-cta__wrapper reveal">
      <div class="acid-cta__content">
        <span class="cmn-tag p2-bg" style="color:#fff;">Limited Availability — 5 Audits / Month</span>
        <h2>Not Sure Where You Stand?<br>Take the <span class="p1-clr">Free A.C.I.D Test.</span></h2>
        <p>We'll run your website through our proprietary A.C.I.D framework and deliver a personalised audit report covering your technical SEO health, content gaps, integration leaks, and data opportunities — absolutely free.</p>
        <ul class="acid-cta__checklist">
          <li><i class="fa-solid fa-circle-check"></i> <strong>25-Point SEO Audit</strong> — technical foundation check</li>
          <li><i class="fa-solid fa-circle-check"></i> <strong>Competitor Gap Analysis</strong> — who is stealing your buyers?</li>
          <li><i class="fa-solid fa-circle-check"></i> <strong>E-E-A-T Assessment</strong> — does your content build trust?</li>
          <li><i class="fa-solid fa-circle-check"></i> <strong>Conversion Mapping</strong> — why aren't visitors enquiring?</li>
        </ul>
        <div class="acid-test__note">
          <i class="fa-solid fa-clock-rotate-left"></i>
          <span>Typically delivered within 48-72 hours.</span>
        </div>
      </div>

      <div class="acid-cta__form-card">
        <h3>Take the Free A.C.I.D Test</h3>
        <p class="lead-form__sub">Fill in your details. We'll do the rest.</p>
        <form class="acid-form" id="acidForm">
          <div class="form-group">
            <label for="fullName">Full Name <span class="required">*</span></label>
            <input type="text" id="fullName" name="fullName" placeholder="e.g. Rahul Sharma" required>
          </div>
          <div class="form-group">
            <label for="companyName">Company Name <span class="required">*</span></label>
            <input type="text" id="companyName" name="companyName" placeholder="e.g. Sharma Packaging LLP" required>
          </div>
          <div class="form-group">
            <label for="websiteUrl">Website URL <span class="required">*</span></label>
            <input type="url" id="websiteUrl" name="websiteUrl" placeholder="https://yourwebsite.com" required>
          </div>
          <div class="form-group">
            <label for="whatsappNumber">WhatsApp Number <span class="required">*</span></label>
            <input type="tel" id="whatsappNumber" name="whatsappNumber" placeholder="+91 XXXXX XXXXX" required>
          </div>
          <div class="form-group">
            <label for="productSector">Primary Product/Sector <span class="optional">(Optional)</span></label>
            <input type="text" id="productSector" name="productSector" placeholder="e.g. Rigid Box Manufacturing">
          </div>
          <button type="submit" class="common-btn p1-bg box-style w-100" style="margin-top:10px;">
            Submit for Free Audit &nbsp;<i class="fa-solid fa-paper-plane"></i>
          </button>
          <p class="form-footer"><i class="fa-solid fa-lock"></i> Your data is safe. No spam. Only data.</p>
        </form>
      </div>
    </div>
  </div>
</section>

</BaseLayout>
