---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Website Development — B2B Digital Factory Websites | Square Root SEO" description="SEO-first, conversion-optimised websites built for B2B manufacturers. From 10-page foundations to 20+ page Digital Factories that generate leads 24/7." activePage="website-development">

<section class="page-hero service-hero--foundry">
  <div class="container text-center">
    <span class="cmn-tag p3-bg" style="color:var(--n900-clr);">Core Service</span>
    <h1>Website <span class="p3-clr">Development</span></h1>
    <p class="page-hero__sub">SEO-first websites built as Digital Factories for B2B manufacturers. Not just a good-looking site, but a system that brings in leads.</p>
    <div class="service-hero__badges">
      <span class="service-badge"><i class="fa-solid fa-laptop-code"></i> Custom Design</span>
      <span class="service-badge"><i class="fa-solid fa-mobile-screen"></i> Mobile-Responsive</span>
      <span class="service-badge"><i class="fa-solid fa-bolt"></i> Fast Loading</span>
    </div>
  </div>
</section>

<section class="service-includes">
  <div class="container">
    <div class="section-title text-center reveal">
      <span class="cmn-tag p3-bg" style="color:var(--n900-clr);">What's Included</span>
      <h2>Your B2B Website, Built to Convert</h2>
      <p style="max-width:650px; margin:10px auto 0; color:var(--text-muted);">Design, development, and deployment. A manufacturing website that captures visitors, tracks leads, and generates enquiries around the clock.</p>
    </div>
    <div class="service-cards-grid service-cards-grid--three">
      <div class="service-detail-card reveal">
        <div class="service-detail-card__icon" style="background:rgba(32,109,255,0.08);"><i class="fa-solid fa-pen-ruler p1-clr"></i></div>
        <h3>Design &amp; UX</h3>
        <p class="service-detail-card__tagline">Custom B2B Brand Experience</p>
        <ul class="service-detail-card__list">
          <li><i class="fa-solid fa-check"></i> Custom design tailored to your B2B brand identity</li>
          <li><i class="fa-solid fa-check"></i> Conversion-optimised layout with clear CTAs</li>
          <li><i class="fa-solid fa-check"></i> Product and service pages with detailed info</li>
          <li><i class="fa-solid fa-check"></i> Mobile-responsive layout for all devices</li>
          <li><i class="fa-solid fa-check"></i> Clean, professional UI that builds trust with buyers</li>
        </ul>
        <div class="service-detail-card__outcome">
          <strong><i class="fa-solid fa-bullseye p1-clr"></i> Outcome:</strong>
          A professional website that represents your manufacturing capabilities and builds buyer confidence.
        </div>
      </div>
      <div class="service-detail-card reveal">
        <div class="service-detail-card__icon" style="background:rgba(255,181,37,0.08);"><i class="fa-solid fa-gears p3-clr"></i></div>
        <h3>Development &amp; Performance</h3>
        <p class="service-detail-card__tagline">Speed, Security &amp; SEO-Ready</p>
        <ul class="service-detail-card__list">
          <li><i class="fa-solid fa-check"></i> Fast loading speed (under 3 seconds)</li>
          <li><i class="fa-solid fa-check"></i> SSL security certificate setup</li>
          <li><i class="fa-solid fa-check"></i> SEO-first architecture and clean code</li>
          <li><i class="fa-solid fa-check"></i> Blog section for content marketing</li>
          <li><i class="fa-solid fa-check"></i> Server-side rendering ready</li>
        </ul>
        <div class="service-detail-card__outcome">
          <strong><i class="fa-solid fa-bullseye p3-clr"></i> Outcome:</strong>
          A fast, secure, and SEO-optimised site that Google loves to rank.
        </div>
      </div>
      <div class="service-detail-card reveal">
        <div class="service-detail-card__icon" style="background:rgba(236,25,30,0.08);"><i class="fa-solid fa-chart-line p2-clr"></i></div>
        <h3>Lead Capture &amp; Tracking</h3>
        <p class="service-detail-card__tagline">Convert Visitors Into Enquiries</p>
        <ul class="service-detail-card__list">
          <li><i class="fa-solid fa-check"></i> Contact forms with WhatsApp integration</li>
          <li><i class="fa-solid fa-check"></i> Advanced CRM and call tracking integration</li>
          <li><i class="fa-solid fa-check"></i> Google Analytics 4 + Search Console setup</li>
          <li><i class="fa-solid fa-check"></i> Lead capture and enquiry tracking system</li>
          <li><i class="fa-solid fa-check"></i> Conversion tracking and goal measurement</li>
        </ul>
        <div class="service-detail-card__outcome">
          <strong><i class="fa-solid fa-bullseye p2-clr"></i> Outcome:</strong>
          Not just a website - a fully automated Digital Factory that captures, tracks, and converts every visitor.
        </div>
      </div>
    </div>
  </div>
</section>

<section class="page-cta reveal">
  <div class="container text-center">
    <h2>Ready to Build Your <span class="p3-clr">Digital Factory?</span></h2>
    <p>Let's create a website that works as hard as your factory floor.</p>
    <div style="display:flex; justify-content:center; gap:20px; flex-wrap:wrap; margin-top:30px;">
      <a href="/contact" class="common-btn p3-bg box-style" style="color:var(--n900-clr);">Get Started <i class="fa-solid fa-arrow-right-long"></i></a>
      <a href="/acid-test" class="common-btn p1-bg box-style">Take Free ACID Test <i class="fa-solid fa-flask-vial"></i></a>
    </div>
  </div>
</section>

</BaseLayout>
