---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Social Media Management - LinkedIn & Meta for B2B | Square Root SEO" description="LinkedIn and Meta social media management for B2B manufacturers. Content calendar, campaigns, and performance reporting." activePage="social-media">

<section class="page-hero service-hero--factory">
  <div class="container text-center">
    <span class="cmn-tag p3-bg" style="color:var(--n900-clr);">Core Service</span>
    <h1>Social Media <span class="p3-clr">Management</span></h1>
    <p class="page-hero__sub">LinkedIn and Meta campaigns for brand awareness among procurement officers, dealers, and decision-makers.</p>
    <div class="service-hero__badges">
      <span class="service-badge"><i class="fa-brands fa-linkedin"></i> LinkedIn</span>
      <span class="service-badge"><i class="fa-brands fa-meta"></i> Meta</span>
      <span class="service-badge"><i class="fa-solid fa-calendar"></i> Content Calendar</span>
    </div>
  </div>
</section>

<section class="service-includes">
  <div class="container">
    <div class="section-title text-center reveal">
      <span class="cmn-tag p3-bg" style="color:var(--n900-clr);">What's Included</span>
      <h2>B2B Social Media That Builds Authority</h2>
    </div>
    <div class="service-cards-grid">
      <div class="service-detail-card reveal">
        <div class="service-detail-card__icon" style="background:rgba(32,109,255,0.08);"><i class="fa-brands fa-linkedin p1-clr"></i></div>
        <h3>LinkedIn Strategy</h3>
        <p class="service-detail-card__tagline">B2B Authority Building</p>
        <ul class="service-detail-card__list">
          <li><i class="fa-solid fa-check"></i> Company page setup and optimisation</li>
          <li><i class="fa-solid fa-check"></i> Industry expertise posts and case studies</li>
          <li><i class="fa-solid fa-check"></i> Targeted campaigns for procurement decision-makers</li>
          <li><i class="fa-solid fa-check"></i> Monthly content calendar</li>
          <li><i class="fa-solid fa-check"></i> Community engagement management</li>
          <li><i class="fa-solid fa-check"></i> Monthly performance reports</li>
        </ul>
        <div class="service-detail-card__outcome"><strong><i class="fa-solid fa-bullseye p1-clr"></i> Outcome:</strong> Brand visibility among procurement officers on LinkedIn.</div>
      </div>
      <div class="service-detail-card reveal">
        <div class="service-detail-card__icon" style="background:rgba(255,181,37,0.08);"><i class="fa-brands fa-meta p3-clr"></i></div>
        <h3>Meta (Facebook/Instagram)</h3>
        <p class="service-detail-card__tagline">Brand Awareness Campaigns</p>
        <ul class="service-detail-card__list">
          <li><i class="fa-solid fa-check"></i> Meta brand awareness ad campaigns</li>
          <li><i class="fa-solid fa-check"></i> Visual content creation for manufacturing</li>
          <li><i class="fa-solid fa-check"></i> Audience targeting for B2B verticals</li>
          <li><i class="fa-solid fa-check"></i> Consistent content across LinkedIn and Meta</li>
          <li><i class="fa-solid fa-check"></i> Performance tracking and optimisation</li>
        </ul>
        <div class="service-detail-card__outcome"><strong><i class="fa-solid fa-bullseye p3-clr"></i> Outcome:</strong> Brand reach across Meta platforms for dealers and distributors.</div>
      </div>
    </div>
  </div>
</section>

<section class="page-cta reveal">
  <div class="container text-center">
    <h2>Ready to Build <span class="p3-clr">Social Authority?</span></h2>
    <p>Position your brand where decision-makers spend their time.</p>
    <div style="display:flex; justify-content:center; gap:20px; flex-wrap:wrap; margin-top:30px;">
      <a href="/contact" class="common-btn p3-bg box-style" style="color:var(--n900-clr);">Get Started <i class="fa-solid fa-arrow-right-long"></i></a>
      <a href="/acid-test" class="common-btn p1-bg box-style">Take Free ACID Test <i class="fa-solid fa-flask-vial"></i></a>
    </div>
  </div>
</section>

</BaseLayout>
