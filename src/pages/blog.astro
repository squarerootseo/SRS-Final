---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Blog — B2B SEO Insights for Manufacturers | Square Root SEO" description="B2B SEO insights, digital marketing tips, and manufacturing industry strategies from Square Root SEO. Read. Learn. Rank." activePage="blog">

<!-- HERO -->
<section class="page-hero">
  <div class="container text-center">
    <span class="cmn-tag p1-bg">Insights &amp; Strategy</span>
    <h1>B2B Digital Marketing <span class="p1-clr">Blog</span></h1>
    <p class="page-hero__sub">Practical insights for B2B manufacturers: SEO, lead generation, AI readiness, and Digital Factory strategies.</p>
  </div>
</section>

<!-- BLOG POSTS GRID -->
<section class="blog" id="blog-posts" style="padding: 80px 0;">
  <div class="container">
    <div class="section-title text-center reveal">
      <span class="cmn-tag p3-bg">B2B SEO Insights</span>
      <h2>Read. Learn. Rank.</h2>
    </div>
    <div class="blog__grid" style="display:grid; grid-template-columns:repeat(3, 1fr); gap:30px; margin-top:48px;">
      <div class="blog-card reveal">
        <span class="blog-card__badge" style="background:var(--p1-clr); color:#fff;">SEO</span>
        <h3>Why B2B Manufacturers Must Stop Depending on Third-Party Marketplaces</h3>
        <p class="pra">A breakdown of what third-party marketplaces cost you per lead vs what an optimised website costs you.</p>
        <a href="#" class="btn-link">Read More <i class="fa-solid fa-arrow-right-long"></i></a>
      </div>
      <div class="blog-card reveal" style="transition-delay:0.1s;">
        <span class="blog-card__badge" style="background:var(--p2-clr); color:#fff;">A.C.I.D Framework</span>
        <h3>What is a Digital Factory and How is it Different From a Website</h3>
        <p class="pra">Understanding the gap between a static website and a fully working lead generation system.</p>
        <a href="#" class="btn-link">Read More <i class="fa-solid fa-arrow-right-long"></i></a>
      </div>
      <div class="blog-card reveal" style="transition-delay:0.2s;">
        <span class="blog-card__badge" style="background:var(--p3-clr); color:var(--n900-clr);">E-E-A-T</span>
        <h3>How E-E-A-T Helps Industrial Websites Rank on Google</h3>
        <p class="pra">Google rewards experience and authority. Here is how we apply that for B2B manufacturers.</p>
        <a href="#" class="btn-link">Read More <i class="fa-solid fa-arrow-right-long"></i></a>
      </div>
    </div>
  </div>
</section>

<section class="page-cta reveal">
  <div class="container text-center">
    <h2>Want These Strategies <span class="p3-clr">Applied to Your Business?</span></h2>
    <p>Stop reading about results. Start getting them.</p>
    <div style="display:flex; justify-content:center; gap:20px; flex-wrap:wrap; margin-top:30px;">
      <a href="/acid-test" class="common-btn p1-bg box-style">Take Free ACID Test <i class="fa-solid fa-flask-vial"></i></a>
      <a href="/contact" class="common-btn p3-bg box-style">Contact Us <i class="fa-solid fa-arrow-right-long"></i></a>
    </div>
  </div>
</section>

</BaseLayout>
