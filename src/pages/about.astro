---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Us — Square Root SEO | B2B Digital Growth Partner" description="Square Root SEO is a B2B-only digital marketing agency helping Indian manufacturers generate qualified leads from Google using the proprietary A.C.I.D Framework." activePage="about">

<!-- HERO -->
<section class="page-hero">
  <div class="container text-center">
    <span class="cmn-tag p1-bg">About Us</span>
    <h1>Built for <span class="p1-clr">B2B Manufacturers.</span> Only.</h1>
    <p class="page-hero__sub">We're a specialist digital marketing agency with one singular focus — helping Indian B2B manufacturers generate qualified leads from Google.</p>
  </div>
</section>

<section class="about-usp">
  <div class="container">
    <div class="section-title text-center reveal">
      <span class="cmn-tag p1-bg">Why Choose Us</span>
      <h2>What Makes Square Root SEO Different</h2>
    </div>
    <div class="about-usp__grid reveal">
      <div class="about-usp__card">
        <div class="about-usp__icon" style="background:rgba(32,109,255,0.1);"><i class="fa-solid fa-industry p1-clr"></i></div>
        <h4>100% B2B Industrial Focus</h4>
        <p>We don't work with restaurants, salons, or e-commerce stores. Every client is a B2B manufacturer. This focus means we understand your buyers, your keywords, and your sales cycle better than any generic agency ever could.</p>
      </div>
      <div class="about-usp__card">
        <div class="about-usp__icon" style="background:rgba(255,181,37,0.1);"><i class="fa-solid fa-flask-vial p3-clr"></i></div>
        <h4>Proprietary A.C.I.D Framework</h4>
        <p>Not a checklist. A structured, 4-phase system (Architect, Content, Integration, Data) that has been tested and refined across 50+ manufacturing businesses to deliver repeatable, measurable results.</p>
      </div>
      <div class="about-usp__card">
        <div class="about-usp__icon" style="background:rgba(236,25,30,0.1);"><i class="fa-solid fa-chart-column p2-clr"></i></div>
        <h4>Data-Driven, Not Guesswork</h4>
        <p>Every keyword we target, every page we build, every content piece we write is backed by real search data, competitor analysis, and buyer intent research. No vanity metrics — only lead generation.</p>
      </div>
      <div class="about-usp__card">
        <div class="about-usp__icon" style="background:rgba(12,12,14,0.05);"><i class="fa-solid fa-trophy n900-clr"></i></div>
        <h4>Proven Results, Not Promises</h4>
        <p>50+ Digital Factories built. 350% average traffic increase. ₹5+ Cr in B2B revenue generated. These aren't projections — they're proven, documented results from real manufacturing clients.</p>
      </div>
    </div>
  </div>
</section>

<!-- STATS BAR -->
<section class="stats-bar">
  <div class="container">
    <div class="stat-item reveal">
      <div class="stat-item__number" data-count="50" data-suffix="+">0</div>
      <div class="stat-item__label">Digital Factories Built</div>
    </div>
    <div class="stat-item reveal" style="transition-delay:0.1s;">
      <div class="stat-item__number" data-count="350" data-suffix="%">0</div>
      <div class="stat-item__label">Average Traffic Increase</div>
    </div>
    <div class="stat-item reveal" style="transition-delay:0.2s;">
      <div class="stat-item__number" data-count="5" data-prefix="₹" data-suffix="+ Cr">0</div>
      <div class="stat-item__label">B2B Revenue Generated</div>
    </div>
    <div class="stat-item reveal" style="transition-delay:0.3s;">
      <div class="stat-item__number" data-count="100" data-suffix="%">0</div>
      <div class="stat-item__label">B2B Industrial Focus</div>
    </div>
  </div>
</section>

<!-- CTA BANNER -->
<section class="page-cta reveal">
  <div class="container text-center">
    <h2>Ready to Work <span class="p3-clr">With Us?</span></h2>
    <p>Let's turn your physical factory into a digital lead generation machine.</p>
    <div style="display:flex; justify-content:center; gap:20px; flex-wrap:wrap; margin-top:30px;">
      <a href="/contact" class="common-btn p3-bg box-style">Contact Us <i class="fa-solid fa-arrow-right-long"></i></a>
      <a href="/acid-test" class="common-btn p1-bg box-style">Take Free ACID Test <i class="fa-solid fa-flask-vial"></i></a>
    </div>
  </div>
</section>

</BaseLayout>
