---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pay Per Click (PPC) - Google Ads for B2B Manufacturers | Square Root SEO" description="Google Ads campaigns built for industrial buyers. Targeted PPC management, keyword bidding, and landing page optimisation for qualified B2B leads." activePage="ppc">

<section class="page-hero" style="background:linear-gradient(135deg, rgba(236,25,30,0.04) 0%, var(--cmnbg) 100%);">
  <div class="container text-center">
    <span class="cmn-tag p2-bg">Domination Exclusive</span>
    <h1>Pay Per Click <span class="p2-clr">(PPC)</span></h1>
    <p class="page-hero__sub">Google Ads campaigns built for industrial buyers. Targeted, measurable, and optimised to generate qualified B2B enquiries from day one.</p>
    <div class="service-hero__badges">
      <span class="service-badge"><i class="fa-solid fa-bullseye"></i> Google Ads</span>
      <span class="service-badge"><i class="fa-solid fa-rotate"></i> Remarketing</span>
      <span class="service-badge"><i class="fa-solid fa-chart-column"></i> ROI Tracking</span>
    </div>
  </div>
</section>

<section class="service-includes">
  <div class="container">
    <div class="section-title text-center reveal">
      <span class="cmn-tag p2-bg">What's Included</span>
      <h2>Google Ads That Generate Real B2B Leads</h2>
      <p style="max-width:650px; margin:10px auto 0; color:var(--text-muted);">Campaign setup, bid management, budget tracking. Full PPC management designed for B2B manufacturing leads.</p>
    </div>
    <div class="service-cards-grid">
      <div class="service-detail-card reveal">
        <div class="service-detail-card__icon" style="background:rgba(236,25,30,0.08);"><i class="fa-solid fa-bullseye p2-clr"></i></div>
        <h3>Campaign Management</h3>
        <p class="service-detail-card__tagline">Setup, Bidding &amp; Optimisation</p>
        <ul class="service-detail-card__list">
          <li><i class="fa-solid fa-check"></i> Google Ads campaign setup and management</li>
          <li><i class="fa-solid fa-check"></i> Keyword bidding strategy for B2B buyers</li>
          <li><i class="fa-solid fa-check"></i> Landing page optimisation for ad campaigns</li>
          <li><i class="fa-solid fa-check"></i> Negative keyword management</li>
          <li><i class="fa-solid fa-check"></i> A/B testing for ad copy and creatives</li>
          <li><i class="fa-solid fa-check"></i> Monthly ROI reporting and budget optimisation</li>
          <li><i class="fa-solid fa-check"></i> Remarketing and display ad campaigns</li>
        </ul>
        <div class="service-detail-card__outcome">
          <strong><i class="fa-solid fa-bullseye p2-clr"></i> Outcome:</strong>
          Instant visibility on Google with targeted campaigns that generate qualified B2B enquiries from day one.
        </div>
      </div>
      <div class="service-detail-card reveal">
        <div class="service-detail-card__icon" style="background:rgba(32,109,255,0.08);"><i class="fa-solid fa-chart-line p1-clr"></i></div>
        <h3>Tracking &amp; Reporting</h3>
        <p class="service-detail-card__tagline">Data-Driven Decisions</p>
        <ul class="service-detail-card__list">
          <li><i class="fa-solid fa-check"></i> Conversion tracking setup</li>
          <li><i class="fa-solid fa-check"></i> Call tracking integration</li>
          <li><i class="fa-solid fa-check"></i> Monthly performance dashboards</li>
          <li><i class="fa-solid fa-check"></i> Cost-per-lead analysis</li>
          <li><i class="fa-solid fa-check"></i> Competitor ad analysis</li>
          <li><i class="fa-solid fa-check"></i> Budget allocation recommendations</li>
        </ul>
        <div class="service-detail-card__outcome">
          <strong><i class="fa-solid fa-bullseye p1-clr"></i> Outcome:</strong>
          Full transparency into every rupee spent. You'll know exactly what's working and what to scale.
        </div>
      </div>
    </div>
  </div>
</section>

<section class="page-cta reveal" style="background:linear-gradient(135deg, var(--n900-clr), #1a1a2e);">
  <div class="container text-center">
    <h2>Ready for <span class="p2-clr">Instant Leads?</span></h2>
    <p>Start generating qualified B2B enquiries from Google Ads today.</p>
    <div style="display:flex; justify-content:center; gap:20px; flex-wrap:wrap; margin-top:30px;">
      <a href="/contact" class="common-btn p2-bg box-style">Start PPC Campaign <i class="fa-solid fa-arrow-right-long"></i></a>
      <a href="/acid-test" class="common-btn p1-bg box-style">Take Free ACID Test <i class="fa-solid fa-flask-vial"></i></a>
    </div>
  </div>
</section>

</BaseLayout>
