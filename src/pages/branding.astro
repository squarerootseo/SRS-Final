---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Branding — B2B Brand Identity Design | Square Root SEO" description="Complete brand identity design for B2B manufacturers. Logo, colour palette, business cards, brand guidelines, and presentation templates." activePage="branding">

<section class="page-hero" style="background:linear-gradient(135deg, rgba(236,25,30,0.04) 0%, var(--cmnbg) 100%);">
  <div class="container text-center">
    <span class="cmn-tag p2-bg">Domination Exclusive</span>
    <h1>Brand Identity <span class="p2-clr">Design</span></h1>
    <p class="page-hero__sub">A clean, professional brand identity that builds trust with procurement officers and makes your company look the part.</p>
    <div class="service-hero__badges">
      <span class="service-badge"><i class="fa-solid fa-palette"></i> Logo Design</span>
      <span class="service-badge"><i class="fa-solid fa-swatchbook"></i> Brand Guidelines</span>
      <span class="service-badge"><i class="fa-solid fa-id-card"></i> Collateral</span>
    </div>
  </div>
</section>

<section class="service-includes">
  <div class="container">
    <div class="section-title text-center reveal">
      <span class="cmn-tag p2-bg">What's Included</span>
      <h2>Complete B2B Brand Identity System</h2>
    </div>
    <div class="service-cards-grid">
      <div class="service-detail-card reveal">
        <div class="service-detail-card__icon" style="background:rgba(236,25,30,0.08);"><i class="fa-solid fa-pen-nib p2-clr"></i></div>
        <h3>Visual Identity</h3>
        <p class="service-detail-card__tagline">Logo, Colour &amp; Typography</p>
        <ul class="service-detail-card__list">
          <li><i class="fa-solid fa-check"></i> Logo refinement or full redesign</li>
          <li><i class="fa-solid fa-check"></i> Brand colour palette and typography system</li>
          <li><i class="fa-solid fa-check"></i> Business card and letterhead design</li>
          <li><i class="fa-solid fa-check"></i> Email signature and presentation templates</li>
          <li><i class="fa-solid fa-check"></i> Brand guidelines document</li>
        </ul>
        <div class="service-detail-card__outcome"><strong><i class="fa-solid fa-bullseye p2-clr"></i> Outcome:</strong> A unified brand identity that builds buyer trust.</div>
      </div>
      <div class="service-detail-card reveal">
        <div class="service-detail-card__icon" style="background:rgba(32,109,255,0.08);"><i class="fa-solid fa-print p1-clr"></i></div>
        <h3>Marketing Collateral</h3>
        <p class="service-detail-card__tagline">Print &amp; Digital Assets</p>
        <ul class="service-detail-card__list">
          <li><i class="fa-solid fa-check"></i> Product catalogue and brochure design</li>
          <li><i class="fa-solid fa-check"></i> Social media brand kit (templates and covers)</li>
          <li><i class="fa-solid fa-check"></i> Trade show and exhibition materials</li>
          <li><i class="fa-solid fa-check"></i> Packaging design consultation</li>
          <li><i class="fa-solid fa-check"></i> Digital ad creative templates</li>
        </ul>
        <div class="service-detail-card__outcome"><strong><i class="fa-solid fa-bullseye p1-clr"></i> Outcome:</strong> Professional collateral across every touchpoint.</div>
      </div>
    </div>
  </div>
</section>

<section class="page-cta reveal" style="background:linear-gradient(135deg, var(--n900-clr), #1a1a2e);">
  <div class="container text-center">
    <h2>Ready for a <span class="p2-clr">Premium Brand?</span></h2>
    <p>Build a brand identity that buyers take seriously from the first impression.</p>
    <div style="display:flex; justify-content:center; gap:20px; flex-wrap:wrap; margin-top:30px;">
      <a href="/contact" class="common-btn p2-bg box-style">Get Started <i class="fa-solid fa-arrow-right-long"></i></a>
      <a href="/acid-test" class="common-btn p1-bg box-style">Take Free ACID Test <i class="fa-solid fa-flask-vial"></i></a>
    </div>
  </div>
</section>

</BaseLayout>
