---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Square Root SEO - B2B Digital Factory | SEO for Manufacturers" description="Square Root SEO builds Digital Factories for B2B manufacturers. SEO, PPC, Social Media, and Website Development that generates qualified leads 24/7." activePage="home">

<!-- S2 HERO -->
<section class="hero">
  <div class="hero-glow"></div>
  <div class="container">
    <div class="hero__content reveal">
      <span class="cmn-tag p3-bg">B2B Digital Growth Partner</span>
      <h1 class="hero__heading">We Build <span class="p1-clr">Digital Factories</span> for B2B Manufacturers</h1>
      <p class="hero__subtext">Your physical factory runs 24/7. Your website should too. We turn your site into a lead engine using our A.C.I.D Framework, designed and tested for Indian B2B manufacturers.</p>
      <div class="hero__ctas">
        <a href="/contact" class="common-btn p1-bg box-style">Build My Factory <i class="fa-solid fa-arrow-right-long"></i></a>
        <a href="/acid-test" class="common-btn p3-bg box-style" style="color:var(--n900-clr);">Take Free ACID Test <i class="fa-solid fa-flask-vial"></i></a>
      </div>
    </div>
    <div class="hero__image reveal">
      <img src="/hero_illustration.png" alt="Digital Factory Illustration">
      <div class="hero-particles">
        <i class="fa-solid fa-magnifying-glass hero-particle" style="--y:15%;--dur:3.5s;--delay:0s;"></i>
        <i class="fa-solid fa-chart-line hero-particle" style="--y:35%;--dur:4s;--delay:0.6s;"></i>
        <i class="fa-solid fa-globe hero-particle" style="--y:55%;--dur:3.8s;--delay:1.2s;"></i>
        <i class="fa-solid fa-envelope hero-particle" style="--y:75%;--dur:4.2s;--delay:0.3s;"></i>
        <i class="fa-solid fa-bullseye hero-particle" style="--y:25%;--dur:3.6s;--delay:1.8s;"></i>
        <i class="fa-solid fa-gear hero-particle" style="--y:60%;--dur:4.4s;--delay:0.9s;"></i>
        <i class="fa-solid fa-code hero-particle" style="--y:45%;--dur:3.9s;--delay:1.5s;"></i>
        <i class="fa-solid fa-rocket hero-particle" style="--y:80%;--dur:3.7s;--delay:2.1s;"></i>
      </div>
    </div>
  </div>
</section>

<!-- S3 STATS BAR -->
<section class="stats-bar">
  <div class="container">
    <div class="stat-item reveal">
      <div class="stat-item__number" data-count="50" data-suffix="+">0</div>
      <div class="stat-item__label">Digital Factories Built</div>
    </div>
    <div class="stat-item reveal" style="transition-delay:0.1s;">
      <div class="stat-item__number" data-count="350" data-suffix="%">0</div>
      <div class="stat-item__label">Average Traffic Increase</div>
    </div>
    <div class="stat-item reveal" style="transition-delay:0.2s;">
      <div class="stat-item__number" data-count="5" data-prefix="₹" data-suffix="+ Cr">0</div>
      <div class="stat-item__label">B2B Revenue Generated</div>
    </div>
    <div class="stat-item reveal" style="transition-delay:0.3s;">
      <div class="stat-item__number" data-count="24" data-suffix="/7">0</div>
      <div class="stat-item__label">Lead Gen Automated</div>
    </div>
  </div>
</section>

<!-- FEATURES STRIP -->
<section class="features-section">
  <div class="container">
    <div class="features-wrapper">
      <div class="feature-item reveal">
        <div class="feature-icon p3-bg"><i class="fa-solid fa-lightbulb"></i></div>
        <h4>Simple Solution</h4>
        <p class="pra">We simplify B2B digital growth with a clear, repeatable system that gets you leads.</p>
      </div>
      <div class="feature-item reveal" style="transition-delay:0.1s;">
        <div class="feature-icon p2-bg"><i class="fa-solid fa-headset"></i></div>
        <h4>24/7 Support</h4>
        <p class="pra">We monitor your numbers, send you honest reports, and pick up the phone when you call.</p>
      </div>
      <div class="feature-item reveal" style="transition-delay:0.2s;">
        <div class="feature-icon p3-bg"><i class="fa-solid fa-gears"></i></div>
        <h4>Full Management</h4>
        <p class="pra">Technical SEO, content, CRM integrations, analytics. We handle all of it so you don't have to.</p>
      </div>
      <div class="feature-item reveal" style="transition-delay:0.3s;">
        <div class="feature-icon p1-bg"><i class="fa-solid fa-users"></i></div>
        <h4>Client Oriented</h4>
        <p class="pra">Every strategy starts with how your buyers actually search and what makes them enquire.</p>
      </div>
    </div>
  </div>
</section>

<!-- TOOLS SLIDER -->
<section class="tools-slider">
  <div class="tools-slider__label">Tools We Use</div>
  <div class="tools-slider__track">
    <div class="tools-slider__items">
      <span><i class="fa-brands fa-google"></i> Google Analytics</span>
      <span><i class="fa-brands fa-google"></i> Search Console</span>
      <span><i class="fa-solid fa-magnifying-glass-chart"></i> SEMrush</span>
      <span><i class="fa-solid fa-chart-simple"></i> Ahrefs</span>
      <span><i class="fa-brands fa-hubspot"></i> HubSpot</span>
      <span><i class="fa-brands fa-wordpress"></i> WordPress</span>
      <span><i class="fa-solid fa-envelope-open-text"></i> Mailchimp</span>
      <span><i class="fa-brands fa-figma"></i> Figma</span>
      <span><i class="fa-brands fa-slack"></i> Slack</span>
      <span><i class="fa-solid fa-robot"></i> ChatGPT</span>
      <span><i class="fa-solid fa-database"></i> Screaming Frog</span>
      <span><i class="fa-brands fa-google"></i> Google Ads</span>
      <span><i class="fa-brands fa-meta"></i> Meta Ads</span>
      <span><i class="fa-solid fa-chart-pie"></i> Looker Studio</span>
      <span><i class="fa-solid fa-brain"></i> Claude</span>
      <span><i class="fa-solid fa-atom"></i> Antigravity</span>
      <span><i class="fa-solid fa-wand-magic-sparkles"></i> Gemini</span>
      <span><i class="fa-solid fa-building"></i> Bitrix24</span>
      <span><i class="fa-solid fa-video"></i> Loom</span>
      <span><i class="fa-solid fa-magnifying-glass"></i> Ubersuggest</span>
      <span><i class="fa-solid fa-rocket"></i> Astro</span>
      <span><i class="fa-solid fa-network-wired"></i> Netlify</span>
      <span><i class="fa-solid fa-triangle-exclamation"></i> Vercel</span>
      <span><i class="fa-brands fa-cloudflare"></i> Cloudflare</span>
      <span><i class="fa-solid fa-compass"></i> Perplexity</span>
      <span><i class="fa-solid fa-book-open"></i> NotebookLM</span>
      <!-- Duplicate for seamless loop -->
      <span><i class="fa-brands fa-google"></i> Google Analytics</span>
      <span><i class="fa-brands fa-google"></i> Search Console</span>
      <span><i class="fa-solid fa-magnifying-glass-chart"></i> SEMrush</span>
      <span><i class="fa-solid fa-chart-simple"></i> Ahrefs</span>
      <span><i class="fa-brands fa-hubspot"></i> HubSpot</span>
      <span><i class="fa-brands fa-wordpress"></i> WordPress</span>
      <span><i class="fa-solid fa-envelope-open-text"></i> Mailchimp</span>
      <span><i class="fa-brands fa-figma"></i> Figma</span>
      <span><i class="fa-brands fa-slack"></i> Slack</span>
      <span><i class="fa-solid fa-robot"></i> ChatGPT</span>
      <span><i class="fa-solid fa-database"></i> Screaming Frog</span>
      <span><i class="fa-brands fa-google"></i> Google Ads</span>
      <span><i class="fa-brands fa-meta"></i> Meta Ads</span>
      <span><i class="fa-solid fa-chart-pie"></i> Looker Studio</span>
      <span><i class="fa-solid fa-brain"></i> Claude</span>
      <span><i class="fa-solid fa-atom"></i> Antigravity</span>
      <span><i class="fa-solid fa-wand-magic-sparkles"></i> Gemini</span>
      <span><i class="fa-solid fa-building"></i> Bitrix24</span>
      <span><i class="fa-solid fa-video"></i> Loom</span>
      <span><i class="fa-solid fa-magnifying-glass"></i> Ubersuggest</span>
      <span><i class="fa-solid fa-rocket"></i> Astro</span>
      <span><i class="fa-solid fa-network-wired"></i> Netlify</span>
      <span><i class="fa-solid fa-triangle-exclamation"></i> Vercel</span>
      <span><i class="fa-brands fa-cloudflare"></i> Cloudflare</span>
      <span><i class="fa-solid fa-compass"></i> Perplexity</span>
      <span><i class="fa-solid fa-book-open"></i> NotebookLM</span>
    </div>
  </div>
</section>

<!-- S4 PROBLEM VS SOLUTION -->
<section class="pvs" id="problem">
  <div class="container">
    <div class="section-title text-center" style="margin-bottom:50px;">
      <span class="cmn-tag p2-bg" style="color:#fff;">The Problem</span>
      <h2>Your Website Is a Digital Brochure. Not an Asset.</h2>
    </div>
    <div class="pvs__tabs">
      <button class="pvs__tab active" data-tab="problems"><i class="fa-solid fa-circle-xmark"></i> Third-Party Dependency</button>
      <button class="pvs__tab" data-tab="solutions"><i class="fa-solid fa-circle-check"></i> Digital Presence</button>
    </div>
    <div class="pvs__wrapper">
      <!-- LEFT - Problems -->
      <div class="pvs__side pvs__problems">
        <h3 class="pvs__side-title"><i class="fa-solid fa-circle-xmark"></i> Third-Party Marketplace Dependency</h3>
        <div class="pvs__item">
          <div class="pvs__icon pvs__icon--problem"><i class="fa-solid fa-coins"></i></div>
          <div>
            <h4>Pay-Per-Enquiry Model</h4>
            <p>You pay third-party marketplaces for every lead. No ownership of buyer data, rising costs, and zero control over enquiry quality.</p>
          </div>
        </div>
        <div class="pvs__item">
          <div class="pvs__icon pvs__icon--problem"><i class="fa-solid fa-users-slash"></i></div>
          <div>
            <h4>Shared With Competitors</h4>
            <p>Your listing sits next to 10+ competitors. Buyers compare on price alone - your brand, expertise, and USP get lost entirely.</p>
          </div>
        </div>
        <div class="pvs__item">
          <div class="pvs__icon pvs__icon--problem"><i class="fa-solid fa-eye-slash"></i></div>
          <div>
            <h4>No Brand Visibility on Google</h4>
            <p>The marketplace ranks on Google - you don't. When buyers search for your products, they find the platform, not your company.</p>
          </div>
        </div>
        <div class="pvs__item">
          <div class="pvs__icon pvs__icon--problem"><i class="fa-solid fa-lock"></i></div>
          <div>
            <h4>No Data, No Ownership</h4>
            <p>You can't track buyer journeys, run remarketing, or build a CRM pipeline. The platform owns the relationship - not you.</p>
          </div>
        </div>
      </div>
      <!-- CENTER DIVIDER -->
      <div class="pvs__divider">
        <span>VS</span>
      </div>
      <!-- RIGHT - Solutions -->
      <div class="pvs__side pvs__solutions">
        <h3 class="pvs__side-title"><i class="fa-solid fa-circle-check"></i> Fully Optimised Digital Presence</h3>
        <div class="pvs__item">
          <div class="pvs__icon pvs__icon--solution"><i class="fa-solid fa-magnet"></i></div>
          <div>
            <h4>You Own Every Lead</h4>
            <p>Leads flow directly to your website 24/7 from Google. No middlemen, no per-enquiry fees, full ownership of buyer data.</p>
          </div>
        </div>
        <div class="pvs__item">
          <div class="pvs__icon pvs__icon--solution"><i class="fa-solid fa-trophy"></i></div>
          <div>
            <h4>You Stand Out - Alone</h4>
            <p>Your brand dominates search results for your product category. Buyers land on your site, not a marketplace with 10 competitors.</p>
          </div>
        </div>
        <div class="pvs__item">
          <div class="pvs__icon pvs__icon--solution"><i class="fa-solid fa-ranking-star"></i></div>
          <div>
            <h4>Page 1 Google Rankings</h4>
            <p>Optimised for B2B search intent. Your products rank for the exact keywords procurement officers use to purchase.</p>
          </div>
        </div>
        <div class="pvs__item">
          <div class="pvs__icon pvs__icon--solution"><i class="fa-solid fa-chart-column"></i></div>
          <div>
            <h4>Full Analytics &amp; CRM Pipeline</h4>
            <p>Track every visitor, every keyword, every conversion. CRM, Google Analytics, and Search Console - all wired into your pipeline.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- S5 DIGITAL FACTORY EXPLAINER -->
<section class="explainer" id="explainer">
  <div class="container">
    <div class="section-title text-center reveal">
      <span class="cmn-tag p3-bg">Our Core Concept</span>
      <h2>A Digital Factory is Not a Website. It's a Lead Engine.</h2>
      <p class="mx-auto">Most manufacturer websites sit there looking nice. A Digital Factory actually works. It gets found by buyers on Google, answers their questions, and turns visits into real enquiries. No marketplace fees.</p>
    </div>
    <div class="explainer__grid">
      <div class="category-card reveal">
        <div class="category-card__icon card-icon-1"><i class="fa-solid fa-magnet"></i></div>
        <h3>Attracts Buyers</h3>
        <p class="pra">Ranks on Google for the exact industrial keywords your buyers type when they need a supplier.</p>
      </div>
      <div class="category-card reveal" style="transition-delay:0.1s;">
        <div class="category-card__icon card-icon-3"><i class="fa-solid fa-book-open"></i></div>
        <h3>Educates Decision-Makers</h3>
        <p class="pra">Pages written for procurement officers, plant heads, and purchase managers. Not fluff.</p>
      </div>
      <div class="category-card reveal" style="transition-delay:0.2s;">
        <div class="category-card__icon card-icon-2"><i class="fa-solid fa-bolt"></i></div>
        <h3>Generates Leads 24/7</h3>
        <p class="pra">Enquiries come in from Google while you sleep. No middlemen. No per-lead charges.</p>
      </div>
    </div>
  </div>
</section>

<!-- S6 ACID FRAMEWORK -->
<section class="acid-premium" id="acid">
  <div class="container">
    <div class="section-title text-center reveal">
      <span class="cmn-tag" style="background:rgba(32,109,255,0.1); color:var(--p1-clr); border: 1px solid rgba(32,109,255,0.25);">Our Proprietary Framework</span>
      <h2>The A.C.I.D Framework</h2>
      <p style="color:var(--text-muted); max-width:600px; margin:0 auto;">Four steps. One outcome: qualified B2B leads from Google, built on E-E-A-T principles.</p>
    </div>
    <div class="acid-premium__grid">
      <div class="acid-premium__card reveal" style="--card-clr: #206dff; --card-clr-soft: rgba(32,109,255,0.12); transition-delay:0s;">
        <div class="acid-premium__letter">A</div>
        <div class="acid-premium__step">Step 01</div>
        <div class="acid-premium__icon"><i class="fa-solid fa-compass-drafting"></i></div>
        <h3>Architect</h3>
        <p>We map out your digital blueprint. Site architecture, B2B keyword research, technical SEO setup, and a page hierarchy based on how your buyers actually search.</p>
        <ul class="acid-premium__list">
          <li><i class="fa-solid fa-check"></i> Technical SEO audit</li>
          <li><i class="fa-solid fa-check"></i> Keyword + competitor mapping</li>
          <li><i class="fa-solid fa-check"></i> Site structure planning</li>
        </ul>
      </div>
      <div class="acid-premium__card reveal" style="--card-clr: #ffb525; --card-clr-soft: rgba(255,181,37,0.12); transition-delay:0.1s;">
        <div class="acid-premium__letter">C</div>
        <div class="acid-premium__step">Step 02</div>
        <div class="acid-premium__icon" style="color:var(--p3-clr);"><i class="fa-solid fa-pen-nib"></i></div>
        <h3>Content</h3>
        <p>We write content that procurement officers and purchase managers actually read. Product pages, category pages, case studies, and blogs that build trust with Google.</p>
        <ul class="acid-premium__list" style="--check-clr: var(--p3-clr);">
          <li><i class="fa-solid fa-check"></i> E-E-A-T content strategy</li>
          <li><i class="fa-solid fa-check"></i> 50+ industrial pages</li>
          <li><i class="fa-solid fa-check"></i> Buyer-first copywriting</li>
        </ul>
      </div>
      <div class="acid-premium__card reveal" style="--card-clr: #ec191e; --card-clr-soft: rgba(236,25,30,0.12); transition-delay:0.2s;">
        <div class="acid-premium__letter">I</div>
        <div class="acid-premium__step">Step 03</div>
        <div class="acid-premium__icon" style="color:var(--p2-clr);"><i class="fa-solid fa-plug-circle-bolt"></i></div>
        <h3>Integration</h3>
        <p>We wire everything together. CRM, lead capture forms, WhatsApp automation, Search Console, and Analytics. All connected and live from day one.</p>
        <ul class="acid-premium__list" style="--check-clr: var(--p2-clr);">
          <li><i class="fa-solid fa-check"></i> CRM &amp; lead form setup</li>
          <li><i class="fa-solid fa-check"></i> WhatsApp automation</li>
          <li><i class="fa-solid fa-check"></i> GSC + Analytics wired</li>
        </ul>
      </div>
      <div class="acid-premium__card reveal" style="--card-clr: #206dff; --card-clr-soft: rgba(32,109,255,0.12); transition-delay:0.3s;">
        <div class="acid-premium__letter">D</div>
        <div class="acid-premium__step">Step 04</div>
        <div class="acid-premium__icon"><i class="fa-solid fa-chart-column"></i></div>
        <h3>Data &amp; Domination</h3>
        <p>Monthly rank tracking, traffic reports, and lead attribution. We keep optimising until your site owns your product category on Google.</p>
        <ul class="acid-premium__list">
          <li><i class="fa-solid fa-check"></i> Rank &amp; traffic reporting</li>
          <li><i class="fa-solid fa-check"></i> Bi-weekly strategy calls</li>
          <li><i class="fa-solid fa-check"></i> Category domination plan</li>
        </ul>
      </div>
    </div>
    <div class="text-center reveal" style="margin-top:60px; transition-delay:0.4s;">
      <p style="color:var(--text-muted); margin-bottom:24px; font-size:17px;">Not sure where you stand? Get a free A.C.I.D audit of your current digital presence.</p>
      <a href="/acid-test" class="common-btn p2-bg box-style" style="font-size:17px; padding:18px 40px;">Get Your Free ACID Test Audit &nbsp;<i class="fa-solid fa-flask"></i></a>
    </div>
  </div>
</section>

<!-- S7 SERVICES GRID -->
<section class="services" id="services">
  <div class="container">
    <div class="section-title text-center reveal">
      <span class="cmn-tag p3-bg">What We Do</span>
      <h2>Three Tiers. One Goal. <span class="p1-clr">Your Growth.</span></h2>
      <p style="max-width:650px; margin:10px auto 0; color:var(--text-muted);">Pick the tier that fits where you are right now, whether you need a foundation or the full package.</p>
    </div>
    <div class="tiers-grid">
      <!-- FOUNDRY -->
      <div class="tier-card reveal">
        <div class="tier-card__header tier-card__header--blue">
          <span class="tier-card__badge">Tier 01</span>
          <div class="tier-card__icon"><i class="fa-solid fa-hammer"></i></div>
          <h3>Foundry</h3>
          <p class="tier-card__tagline">Build Your Digital Foundation</p>
        </div>
        <div class="tier-card__body">
          <p class="tier-card__persona"><i class="fa-solid fa-user p1-clr"></i> <span>Ideal for: </span><strong>New to digital</strong></p>
          <div class="tier-card__services">
            <a href="/seo" class="tier-card__service"><i class="fa-solid fa-magnifying-glass"></i> Search Engine Optimization</a>
            <a href="/website-development" class="tier-card__service"><i class="fa-solid fa-laptop-code"></i> Website Development</a>
          </div>
        </div>
      </div>
      <!-- DIGITAL FACTORY -->
      <div class="tier-card tier-card--featured reveal" style="transition-delay:0.1s;">
        <div class="tier-card__popular"><i class="fa-solid fa-fire"></i> Most Popular</div>
        <div class="tier-card__header tier-card__header--gold">
          <span class="tier-card__badge">Tier 02</span>
          <div class="tier-card__icon"><i class="fa-solid fa-industry"></i></div>
          <h3>Digital Factory</h3>
          <p class="tier-card__tagline">Full Lead Generation System</p>
        </div>
        <div class="tier-card__body">
          <p class="tier-card__persona"><i class="fa-solid fa-user p3-clr"></i> <span>Ideal for: </span><strong>Visibility &amp; AI Readiness</strong></p>
          <div class="tier-card__services">
            <a href="/seo" class="tier-card__service"><i class="fa-solid fa-magnifying-glass-chart"></i> Search Engine Optimization</a>
            <a href="/website-development" class="tier-card__service"><i class="fa-solid fa-laptop-code"></i> Website Development</a>
            <a href="/social-media" class="tier-card__service"><i class="fa-solid fa-share-nodes"></i> Social Media Management</a>
          </div>
        </div>
      </div>
      <!-- DOMINATION -->
      <div class="tier-card reveal" style="transition-delay:0.2s;">
        <div class="tier-card__header tier-card__header--red">
          <span class="tier-card__badge">Tier 03</span>
          <div class="tier-card__icon"><i class="fa-solid fa-rocket"></i></div>
          <h3>Domination</h3>
          <p class="tier-card__tagline">Total Market Domination</p>
        </div>
        <div class="tier-card__body">
          <p class="tier-card__persona"><i class="fa-solid fa-user p2-clr"></i> <span>Ideal for: </span><strong>Total Digital Domination</strong></p>
          <div class="tier-card__services">
            <a href="/seo" class="tier-card__service"><i class="fa-solid fa-magnifying-glass-chart"></i> Search Engine Optimization</a>
            <a href="/website-development" class="tier-card__service"><i class="fa-solid fa-laptop-code"></i> Website Development</a>
            <a href="/social-media" class="tier-card__service"><i class="fa-solid fa-share-nodes"></i> Social Media Management</a>
            <a href="/ppc" class="tier-card__service tier-card__service--exclusive"><i class="fa-solid fa-hand-pointer"></i> Pay Per Click (PPC)</a>
            <a href="/branding" class="tier-card__service tier-card__service--exclusive"><i class="fa-solid fa-palette"></i> Branding</a>
          </div>
        </div>
      </div>
    </div>
    <div class="text-center" style="margin-top: 50px;">
      <h4 style="margin-bottom: 20px;">We Work Exclusively with B2B Sectors:</h4>
      <div style="display:flex; justify-content:center; gap:16px; flex-wrap:wrap;">
        <span class="cmn-tag" style="background:#fff; border:1px solid #ddd; padding:6px 16px; font-size:14px; margin:0;"><i class="fa-solid fa-box p1-clr" style="margin-right:8px;"></i>Packaging</span>
        <span class="cmn-tag" style="background:#fff; border:1px solid #ddd; padding:6px 16px; font-size:14px; margin:0;"><i class="fa-solid fa-gear p2-clr" style="margin-right:8px;"></i>Industrial Supplies</span>
